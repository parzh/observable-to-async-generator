{
  "name": "observable-to-async-generator",
  "description": "Convert an observable to ES6 async generator.",
  "version": "1.1.0",
  "author": "Dmytro Parzhytskyi <parzhitsky@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parzh/observable-to-async-generator.git"
  },
  "bugs": {
    "url": "https://github.com/parzh/observable-to-async-generator/issues"
  },
  "homepage": "https://github.com/parzh/observable-to-async-generator#readme",
  "keywords": [
    "*",
    "async",
    "await",
    "convert",
    "create",
    "function*",
    "function *",
    "generator",
    "iterable",
    "iterator",
    "observable",
    "otag",
    "yield",
    "yield*",
    "yield *"
  ],
  "type": "module",
  "files": [
    "/dist",
    "!/dist/**/*.{spec,test}.*",
    "!/dist/**/*.d.cts",
    "/README.md"
  ],
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run --coverage",
    "lint": "eslint \"**/*.ts\"",
    "build": "tsup && rm -f dist/*.d.cts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@types/eslint__eslintrc": "2.1.2",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitest/coverage-istanbul": "4.1.0",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.2.1",
    "globals": "16.5.0",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "rxjs": "6 || 7"
  }
}
