{
  "name": "observable-to-async-generator",
  "description": "Convert an observable to ES6 async generator.",
  "version": "1.0.5",
  "author": "Dmytro Parzhytskyi <parzhitsky@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parzh/observable-to-async-generator.git"
  },
  "bugs": {
    "url": "https://github.com/parzh/observable-to-async-generator/issues"
  },
  "homepage": "https://github.com/parzh/observable-to-async-generator#readme",
  "keywords": [
    "*",
    "async",
    "await",
    "convert",
    "create",
    "function*",
    "function *",
    "generator",
    "iterable",
    "iterator",
    "observable",
    "otag",
    "yield",
    "yield*",
    "yield *"
  ],
  "type": "module",
  "files": [
    "/dist",
    "!/dist/**/*.{spec,test}.*",
    "/README.md"
  ],
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": true,
    "clearMocks": true,
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/src/**/*.{spec,test}.ts"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.ts",
      "!<rootDir>/{src,test}/**/*.{spec,test}.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "scripts": {
    "test": "jest",
    "lint": "eslint \"**/*.ts\"",
    "prebuild": "rm -rf dist",
    "build": "vite build"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@types/eslint__eslintrc": "2.1.2",
    "@types/jest": "30.0.0",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.2.1",
    "globals": "16.5.0",
    "jest": "30.3.0",
    "rxjs": "7.8.2",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "vite": "7.1.12",
    "vite-plugin-dts": "4.5.4"
  },
  "peerDependencies": {
    "rxjs": "6 || 7"
  }
}
